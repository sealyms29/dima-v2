<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Base path for staging deployment
  RewriteBase /staging/
  
  # Don't rewrite existing files
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Route all requests through index.html for client-side React Router
  # This allows react-router to handle all paths like /about, /services, etc.
  RewriteRule ^ index.html [QSA,L]
</IfModule>
