# ============================================================================
# DIMA Certification - Production .htaccess
# Handles: HTTPS redirect, React SPA routing, PHP passthrough, security
# ============================================================================

# Enable rewrite engine
RewriteEngine On

# ============================================================================
# FORCE HTTPS (uncomment after SSL is active)
# ============================================================================
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================================================
# SECURITY HEADERS
# ============================================================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================================================
# PROTECT SENSITIVE FILES & DIRECTORIES
# ============================================================================

# Block access to includes directory
RewriteRule ^includes/ - [F,L]

# Block access to logs directory
RewriteRule ^logs/ - [F,L]

# Block access to vendor directory (except autoload)
RewriteRule ^vendor/ - [F,L]

# Block .env files
RewriteRule \.env - [F,L]

# Block composer files
RewriteRule ^composer\.(json|lock|phar)$ - [F,L]

# Block config files from direct access
<FilesMatch "\.(ini|log|sh|sql)$">
    Require all denied
</FilesMatch>

# ============================================================================
# PHP FILES - Serve directly
# ============================================================================

# If the request is for an existing PHP file, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_URI} \.php$
RewriteRule ^ - [L]

# API directory - serve PHP files
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Admin directory - serve PHP files
RewriteCond %{REQUEST_URI} ^/admin/ [NC]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Public directory - serve PHP files
RewriteCond %{REQUEST_URI} ^/public/ [NC]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ============================================================================
# STATIC FILES - Serve directly
# ============================================================================

# If the request matches a real file (CSS, JS, images, uploads), serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request matches a real directory, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ============================================================================
# REACT SPA ROUTING - Everything else goes to index.html
# ============================================================================

# All other requests → React SPA
RewriteRule ^ index.html [L]

# ============================================================================
# CACHING
# ============================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    
    # CSS & JavaScript - cache 1 year (hashed filenames)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Images - cache 1 month
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    
    # Fonts - cache 1 year
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # PDF downloads - no cache
    ExpiresByType application/pdf "access plus 0 seconds"
    
    # HTML - no cache (React SPA updates)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ============================================================================
# GZIP COMPRESSION
# ============================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ============================================================================
# PHP SETTINGS
# ============================================================================
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>
