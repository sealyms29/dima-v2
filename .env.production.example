; ============================================================================
; DIMA Production Environment Configuration
; ============================================================================
; Copy this file to .env.production on your cPanel server
; Fill in your actual cPanel MySQL credentials
; This file is in .gitignore and will NOT be committed to GitHub
; ============================================================================

; Database (get these from cPanel > MySQL Databases)
DB_HOST = "localhost"
DB_NAME = "your_cpanel_user_dima"
DB_USER = "your_cpanel_user_dbuser"
DB_PASS = "your_database_password"
